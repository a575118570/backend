# 複製此檔案為 .env 並依需求修改
# Windows: copy env.example .env
# Linux/Mac: cp env.example .env

# ========== 小皮 (XP) 資料庫連線 ==========
# 小皮面板預設: localhost:3306, 使用者 root, 密碼通常為空
# 請先在小皮中建立資料庫 (如 anime_db)
DATABASE_URL=mysql+aiomysql://root:root@localhost:3306/anime_db

# 或分開設定 (DATABASE_URL 優先)
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=root
# DB_NAME=anime_db

# ========== 其他資料庫 ==========
# SQLite (留空 DATABASE_URL 時使用):
# DATABASE_URL=sqlite+aiosqlite:///./anime.db

# PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/anime_db

# ========== 伺服器設定 ==========
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false
